# ===== Base de datos =====
DATABASE_URL=postgresql://usuario:password@localhost:5432/nombre_db

# ===== App =====
NODE_ENV=production
PORT=4000
APP_URL=https://vendi.olcas.app
AUTH_SECRET=
AUTH_URL=https://vendi.olcas.app
AUTH_TRUST_HOST=true

# ===== Servicios del holding =====
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
HUBSPOT_ACCESS_TOKEN=

# ===== Cloudflare R2 (imágenes de producto) =====
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ===== Operación =====
ALERT_EMAIL=

# ===== Dominios (compra asistida con tu código de afiliado) =====
# Plantilla del enlace de compra; {domain} se sustituye por el dominio buscado.
# Ej. Namecheap afiliado: https://namecheap.pxf.io/c/TU_ID/?u=https://www.namecheap.com/domains/registration/results/?domain={domain}
NEXT_PUBLIC_BUY_DOMAIN_URL=

# ===== Web Push (notificaciones de pedidos) =====
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:vendi@olcas.app
